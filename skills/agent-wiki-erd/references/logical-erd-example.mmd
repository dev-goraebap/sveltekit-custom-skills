---
config:
  theme: dark
  look: handDrawn
  layout: elk
---
erDiagram
	direction BT

	직원 {
		Long 직원ID PK ""
		Long 부서ID FK ""
		Long 직위ID FK ""
		String 이름 "NN"
		String 이메일 "UQ"
		Date 입사일 "NN"
		Date 퇴사일 ""
		Enum 재직상태 "NN"
		String 연락처 ""
	}

	부서 {
		Long 부서ID PK ""
		Long 상위부서ID FK ""
		Long 부서장ID FK ""
		String 부서명 "NN, UQ"
		String 부서코드 "UQ"
		Int 정렬순서 ""
		Boolean 활성여부 "NN"
	}

	직위 {
		Long 직위ID PK ""
		String 직위명 "NN, UQ"
		Int 직위등급 "NN"
		Int 정렬순서 ""
	}

	근태 {
		Long 근태ID PK ""
		Long 직원ID FK ""
		Date 근무일 "NN"
		DateTime 출근시각 ""
		DateTime 퇴근시각 ""
		Enum 근태유형 "NN"
		Text 비고 ""
	}

	휴가유형 {
		Long 휴가유형ID PK ""
		String 유형명 "NN, UQ"
		Int 기본일수 "NN"
		Boolean 유급여부 "NN"
	}

	휴가신청 {
		Long 휴가신청ID PK ""
		Long 직원ID FK ""
		Long 휴가유형ID FK ""
		Date 시작일 "NN"
		Date 종료일 "NN"
		Float 사용일수 "NN"
		Enum 승인상태 "NN"
		Text 사유 ""
	}

	급여등급 {
		Long 급여등급ID PK ""
		String 등급명 "NN, UQ"
		Long 기본급 "NN"
		Long 상한액 ""
		Long 하한액 ""
	}

	급여 {
		Long 급여ID PK ""
		Long 직원ID FK ""
		Long 급여등급ID FK ""
		Int 지급년월 "NN"
		Long 기본급 "NN"
		Long 수당합계 ""
		Long 공제합계 ""
		Long 실지급액 "NN"
		Date 지급일 "NN"
	}

	평가기간 {
		Long 평가기간ID PK ""
		String 기간명 "NN"
		Date 시작일 "NN"
		Date 종료일 "NN"
		Enum 평가상태 "NN"
	}

	인사평가 {
		Long 인사평가ID PK ""
		Long 직원ID FK ""
		Long 평가기간ID FK ""
		Long 평가자ID FK ""
		Enum 평가등급 ""
		Int 점수 ""
		Text 코멘트 ""
		DateTime 평가일시 ""
	}

	채용공고 {
		Long 채용공고ID PK ""
		Long 부서ID FK ""
		Long 직위ID FK ""
		String 공고제목 "NN"
		Text 상세내용 ""
		Int 모집인원 "NN"
		Date 시작일 "NN"
		Date 마감일 "NN"
		Enum 공고상태 "NN"
	}

	지원자 {
		Long 지원자ID PK ""
		Long 채용공고ID FK ""
		String 성명 "NN"
		String 이메일 "NN"
		String 연락처 ""
		Text 자기소개 ""
		Enum 전형단계 "NN"
		DateTime 지원일시 "NN"
	}

	교육 {
		Long 교육ID PK ""
		String 교육명 "NN"
		Enum 교육유형 "NN"
		Int 총시간 "NN"
		String 강사명 ""
		Boolean 필수여부 "NN"
	}

	교육수강 {
		Long 교육수강ID PK ""
		Long 직원ID FK ""
		Long 교육ID FK ""
		Date 수강시작일 "NN"
		Date 수강완료일 ""
		Enum 이수상태 "NN"
		Int 점수 ""
	}

	인사이동 {
		Long 인사이동ID PK ""
		Long 직원ID FK ""
		Long 이전부서ID FK ""
		Long 이후부서ID FK ""
		Long 이전직위ID FK ""
		Long 이후직위ID FK ""
		Enum 이동유형 "NN"
		Date 발령일 "NN"
		Text 사유 ""
	}

	직원||--o{근태:"기록된다"
	직원||--o{휴가신청:"신청한다"
	직원||--o{급여:"지급된다"
	직원||--o{인사평가:"평가받는다"
	직원||--o{교육수강:"수강한다"
	직원||--o{인사이동:"이동된다"
	직원}o--||부서:"소속된다"
	직원}o--||직위:"부여된다"
	부서||--o|직원:"관리한다(장)"
	부서||--o{부서:"하위부서"
	부서||--o{채용공고:"공고낸다"
	직위||--o{채용공고:"모집한다"
	휴가유형||--o{휴가신청:"분류된다"
	급여등급||--o{급여:"적용된다"
	평가기간||--o{인사평가:"수행된다"
	채용공고||--o{지원자:"지원한다"
	교육||--o{교육수강:"포함한다"

	직원:::blue
	부서:::teal
	직위:::gold
	근태:::green
	휴가유형:::orange
	휴가신청:::red
	급여등급:::purple
	급여:::lime
	평가기간:::slate
	인사평가:::cyan
	채용공고:::amber
	지원자:::pink
	교육:::indigo
	교육수강:::violet
	인사이동:::sky

	classDef blue stroke-width:1px,stroke-dasharray:none,stroke:#5b6ef5,fill:#1a2040,color:#a4b0ff
	classDef teal stroke-width:1px,stroke-dasharray:none,stroke:#2dd4bf,fill:#0d2926,color:#7eecd8
	classDef gold stroke-width:1px,stroke-dasharray:none,stroke:#f0c040,fill:#2a2408,color:#f5d87a
	classDef green stroke-width:1px,stroke-dasharray:none,stroke:#4ade80,fill:#0f2518,color:#8aedb3
	classDef orange stroke-width:1px,stroke-dasharray:none,stroke:#fb923c,fill:#2a1a0d,color:#fdb97a
	classDef red stroke-width:1px,stroke-dasharray:none,stroke:#f87171,fill:#2a1414,color:#fba4a4
	classDef purple stroke-width:1px,stroke-dasharray:none,stroke:#e879f9,fill:#1f0e2a,color:#f0a8fc
	classDef lime stroke-width:1px,stroke-dasharray:none,stroke:#a3e635,fill:#1a2408,color:#c4ee7a
	classDef slate stroke-width:1px,stroke-dasharray:none,stroke:#94a3b8,fill:#1a1e24,color:#b8c4d4
	classDef cyan stroke-width:1px,stroke-dasharray:none,stroke:#67e8f9,fill:#0e2428,color:#9ef0fb
	classDef amber stroke-width:1px,stroke-dasharray:none,stroke:#fbbf24,fill:#2a2208,color:#fcd76a
	classDef pink stroke-width:1px,stroke-dasharray:none,stroke:#f472b6,fill:#2a1020,color:#f9a4d0
	classDef indigo stroke-width:1px,stroke-dasharray:none,stroke:#818cf8,fill:#181a30,color:#b0b8fb
	classDef violet stroke-width:1px,stroke-dasharray:none,stroke:#a78bfa,fill:#1e1630,color:#c8b4fc
	classDef sky stroke-width:1px,stroke-dasharray:none,stroke:#38bdf8,fill:#0e1e2a,color:#7ed4fb
